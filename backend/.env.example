# ─── TrendLens AI Backend ─ Environment Variables ───────────────────────────
# Copy this file to .env and fill in the values.

# ── MongoDB (Required) ──────────────────────────────────────────────────────
MONGO_URI=mongodb://trendlens:trendlens123@localhost:27017/trendlens?authSource=admin
MONGO_DB_NAME=trendlens
MONGO_MAX_POOL_SIZE=10
MONGO_MIN_POOL_SIZE=2

# ── General ─────────────────────────────────────────────────────────────────
DEBUG=false
LOG_LEVEL=INFO
FLASK_SECRET_KEY=change-me-in-production

# ── API Key (optional — leave empty to disable auth) ───────────────────────
TRENDLENS_API_KEY=

# ── External API Keys (all optional) ───────────────────────────────────────
APIFY_API_TOKEN=
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=
YOUTUBE_API_KEY=
NEWSAPI_KEY=
TWITTER_BEARER_TOKEN=
INSTAGRAM_ACCESS_TOKEN=

# ── Model Training ─────────────────────────────────────────────────────────
RETRAIN_MIN_SAMPLES=30
RETRAIN_INTERVAL_HOURS=24
XGBOOST_MAX_DEPTH=6
XGBOOST_N_ESTIMATORS=200
XGBOOST_LEARNING_RATE=0.1

# ── OCR ─────────────────────────────────────────────────────────────────────
OCR_LANGUAGES=en

# ── Environment ─────────────────────────────────────────────────────────────
ENVIRONMENT=development
