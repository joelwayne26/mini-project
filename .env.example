# TrendLens AI v6.0 Environment Variables
# Copy this to .env and fill in your values

# ── MongoDB (required for full functionality) ────────────────────────────────
# Atlas:  mongodb+srv://user:pass@cluster.mongodb.net/trendlens
MONGO_URI=mongodb://localhost:27017
MONGO_DB_NAME=trendlens
MONGO_MAX_POOL_SIZE=10
MONGO_MIN_POOL_SIZE=2

# ── Feature flags ───────────────────────────────────────────────────────────
RAG_ENABLED=true
SHAP_ENABLED=true
CAPTION_GEN_ENABLED=true

# ── Silent LLM Enhancement (optional but recommended) ──────────────────────
# Set to "true" to enable silent LLM-enhanced scoring, embedding, and insights
ENHANCE=true

# ── Security (set before production) ────────────────────────────────────────
FLASK_SECRET_KEY=change-this-in-production
TRENDLENS_API_KEY=

# ── Optional: Trend data source API keys ───────────────────────────────────
YOUTUBE_API_KEY=
NEWSAPI_KEY=
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=

# ── ML Training ─────────────────────────────────────────────────────────────
RETRAIN_MIN_SAMPLES=10
RETRAIN_INTERVAL_HOURS=24
